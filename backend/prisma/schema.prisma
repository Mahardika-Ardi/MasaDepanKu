model TestSession {
  id         Int      @id @default(autoincrement())
  userId     Int
  status     Status   @default(PENDING)
  aiAnalysis Json?
  createdAt  DateTime @default(now())

  user     Users        @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question[]
  answers  UserAnswer[]
}

model Question {
  id        Int      @id @default(autoincrement())
  sessionId Int
  number    Int
  question  String
  answer    Json
  category  Category

  session TestSession  @relation(fields: [sessionId], references: [id])
  answers UserAnswer[]
}

model UserAnswer {
  id         Int @id @default(autoincrement())
  sessionId  Int
  questionId Int
  value      Int

  session  TestSession @relation(fields: [sessionId], references: [id])
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
}

enum Role {
  USER
  ADMIN
}

enum Category {
  teknis
  sosial
  kreatif
  analitis
  manajerial
}

enum Status {
  PENDING
  COMPLETED
  FAILED
}
