generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Users {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     Role   @default(USER)

  photoProfiles    PhotoProfile?
  profilDetail     ProfilDetail?
  groupQuestions   GroupQuestion[]
  userAnswerGroups UserAnswerGroup[]
}

model PhotoProfile {
  id      Int     @id @default(autoincrement())
  user_id Int     @unique
  file    String?

  user Users @relation(fields: [user_id], references: [id])
}

model ProfilDetail {
  id           Int     @id @default(autoincrement())
  user_id      Int     @unique
  jurusan      String?
  raport_score Json?

  user Users @relation(fields: [user_id], references: [id])
}

model GroupQuestion {
  id      Int @id @default(autoincrement())
  user_id Int

  questions Question[]
  user      Users      @relation(fields: [user_id], references: [id])
}

model Question {
  id       Int      @id @default(autoincrement())
  number   Int
  question String
  answer   Json
  category Category
  group_id Int

  group_question GroupQuestion @relation(fields: [group_id], references: [id])
}

model UserAnswerGroup {
  id      Int @id @default(autoincrement())
  user_id Int

  user        Users        @relation(fields: [user_id], references: [id])
  userAnswers UserAnswer[]
}

model UserAnswer {
  id       Int @id @default(autoincrement())
  group_id Int
  value    Int

  useranswergroup UserAnswerGroup @relation(fields: [group_id], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum Category {
  teknis
  sosial
  kreatif
  analitis
  manajerial
}
